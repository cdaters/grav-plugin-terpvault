{% extends 'partials/base.html.twig' %}

{% block content %}
  {% set game = terpvault_current_game %}
  <article class="terpvault terpvault-detail">
    <nav class="terpvault-breadcrumb"><a href="{{ terpvault.route }}">← Library</a></nav>

    {% set hero_style = game.heroStyle %}
    <header class="terpvault-game-hero{% if hero_style %} terpvault-game-hero-with-image{% endif %}"{% if hero_style %} style="{{ hero_style }}"{% endif %}>
      <div class="terpvault-game-heading">
        <p class="terpvault-kicker">{{ game.formatLabel }}</p>
        <h1>{{ game.title }}</h1>
        {% if game.tagline %}<p class="terpvault-tagline">{{ game.tagline }}</p>{% endif %}
        <p class="terpvault-meta">
          {% if game.author %}<span>By {{ game.author }}</span>{% endif %}
          {% if game.year %}<span>{{ game.year }}</span>{% endif %}
          {% if game.genre %}<span>{{ game.genre }}</span>{% endif %}
          <span>{{ game.status|capitalize }}</span>
        </p>
        <p class="terpvault-hero-actions"><a class="terpvault-button" href="{{ game.url('play') }}">Play {{ game.title }}</a></p>
      </div>

      {% if game.coverUrl %}
        <a class="terpvault-cover-link" href="{{ game.url('play') }}" aria-label="Play {{ game.title }}">
          <img class="terpvault-cover" src="{{ game.coverUrl }}" alt="{{ game.title }} cover art">
        </a>
      {% endif %}
    </header>

    {% if game.splashUrl %}
      <figure class="terpvault-splash">
        <img src="{{ game.splashUrl }}" alt="{{ game.title }} splash image">
      </figure>
    {% endif %}

    {% if game.description %}
      <section class="terpvault-panel terpvault-about">
        <h2>About this game</h2>
        {{ terpvault_markdown(game.description)|raw }}
      </section>
    {% endif %}

    {% set screenshots = game.screenshots %}
    {% if screenshots|length %}
      <section class="terpvault-panel">
        <h2>Screenshots</h2>
        <div class="terpvault-screenshots">
          {% for screenshot in screenshots %}
            <img src="{{ screenshot }}" alt="{{ game.title }} screenshot {{ loop.index }}">
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% set howto = game.markdownPath(game.resourceFile('how_to_play', 'how_to_play')) %}
    {% set hints = game.markdownPath(game.resourceFile('hints', 'hints')) %}
    {% set walkthrough = game.markdownPath(game.resourceFile('walkthrough', 'walkthrough')) %}

    {% if howto or hints or walkthrough %}
      <section class="terpvault-panel terpvault-accordions">
        <h2>Help & Reference</h2>
        <p class="terpvault-section-note">Package-local notes for commands, hints, and solution paths.</p>
        {% if howto %}
          <details open>
            <summary>How to Play</summary>
            <div class="terpvault-detail-body">
              {{ terpvault_render_markdown(howto)|raw }}
            </div>
          </details>
        {% endif %}
        {% if hints %}
          <details>
            <summary>Hints</summary>
            <div class="terpvault-detail-body">
              {{ terpvault_render_markdown(hints)|raw }}
            </div>
          </details>
        {% endif %}
        {% if walkthrough %}
          <details>
            <summary>Walkthrough</summary>
            <div class="terpvault-detail-body">
              {{ terpvault_render_markdown(walkthrough)|raw }}
            </div>
          </details>
        {% endif %}
      </section>
    {% endif %}

    {% set feelies = game.feelies %}
    {% if feelies|length %}
      <section class="terpvault-panel terpvault-feelies">
        <h2>Extras & Feelies</h2>
        <p class="terpvault-section-note">Package-local supplemental files such as manuals, maps, clue sheets, audio, and other extras.</p>
        <div class="terpvault-feelies-list">
          {% for item in feelies %}
            <a class="terpvault-feelie" href="{{ item.url }}" rel="noopener">
              <span>
                <strong>{{ item.title }}</strong>
                {% if item.description %}<small>{{ item.description }}</small>{% endif %}
                <code>{{ item.path }}</code>
              </span>
              <em>{{ item.type ?: item.extension }}</em>
            </a>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% set provenance_rows = game.provenanceRows %}
    {% set advisory_warnings = game.advisoryWarnings %}
    {% set error_count = game.warningCount('error') %}
    {% if provenance_rows|length %}
      <section class="terpvault-panel terpvault-provenance">
        <h2>Catalog & Provenance</h2>
        <p class="terpvault-section-note">Identifiers, source references, and redistribution notes stored with this package.</p>
        <dl class="terpvault-definition-list">
          {% for row in provenance_rows %}
            <dt>{{ row.label }}</dt>
            <dd>
              {% if row.type == 'codes' %}
                {% for value in row.values %}<code>{{ value }}</code>{% if not loop.last %}<br>{% endif %}{% endfor %}
              {% elseif row.type == 'link' %}
                <a href="{{ row.url }}" rel="noopener">{{ row.text }}</a>
                {% if row.note %}<br><span>{{ row.note }}</span>{% endif %}
              {% else %}
                {{ row.text }}
                {% if row.note %}<br><span>{{ row.note }}</span>{% endif %}
              {% endif %}
            </dd>
          {% endfor %}
        </dl>
      </section>
    {% endif %}

    {% if advisory_warnings|length or error_count %}
      <section class="terpvault-panel terpvault-completeness">
        <h2>Package Notes</h2>
        {% if error_count %}
          <p class="terpvault-alert terpvault-alert-error">This package needs a readable story file before it can be played reliably.</p>
        {% endif %}
        {% if advisory_warnings|length %}
          <p class="terpvault-section-note">These are curator-facing completeness notes. They do not prevent the game from being listed or played.</p>
          <ul class="terpvault-warning-list">
            {% for warning in advisory_warnings %}
              <li>
                <strong>{{ warning.label }}</strong>
                <span>{{ warning.message }}</span>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <p class="terpvault-section-note">Core package metadata and helper files are in good shape.</p>
        {% endif %}
      </section>
    {% endif %}
    {% include 'partials/terpvault-version.html.twig' %}
  </article>
{% endblock %}
