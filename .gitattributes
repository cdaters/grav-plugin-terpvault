# Normalize text files for cross-platform contributors.
* text=auto eol=lf

# PHP / Twig / YAML / Markdown / JS / CSS are text.
*.php  text eol=lf
*.twig text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.xml  text eol=lf
*.svg  text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.z1 binary
*.z2 binary
*.z3 binary
*.z4 binary
*.z5 binary
*.z6 binary
*.z7 binary
*.z8 binary
*.zblorb binary
*.ulx binary
*.gblorb binary
*.sav binary
*.glksave binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.html text eol=lf
*.wasm binary
assets/vendor/parchment/index.html text eol=lf -diff
